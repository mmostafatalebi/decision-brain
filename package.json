{
  "name": "decision-brain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A CEO decision brain: typed-fact memory, deterministic retrieval, cited answers, human-in-the-loop decisions, MCP interface.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",

    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "seed": "tsx src/seed.ts",
    "refresh": "pnpm seed && pnpm ingest && pnpm resolve && pnpm relations && pnpm signals && pnpm contradictions",

    "ingest": "tsx src/ingest/index.ts",
    "resolve": "tsx src/entities/index.ts",
    "relations": "tsx src/entities/relations.ts",
    "signals": "tsx src/signals/index.ts",
    "contradictions": "tsx src/contradictions/index.ts",

    "ask": "tsx src/cli/ask.ts",
    "cli": "tsx src/cli/ask.ts",
    "mcp": "tsx src/mcp/server.ts",
    "dev": "tsx src/mcp/server.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@tavily/core": "^0.7.6",
    "drizzle-orm": "^0.36.0",
    "openai": "^4.70.0",
    "pg": "^8.13.0",
    "pgvector": "^0.2.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
