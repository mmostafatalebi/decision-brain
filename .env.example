# LLM providers
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Web research tool
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Postgres 15+ (works on 14) with the pgvector extension installed
DATABASE_URL=postgresql://USER@localhost:5432/decision_brain

# Which provider drives write-time extraction + answer synthesis: anthropic | openai
LLM_PROVIDER=anthropic

# Optional: override the Claude model for extraction + synthesis (default: claude-opus-4-8)
ANTHROPIC_MODEL=claude-opus-4-8
